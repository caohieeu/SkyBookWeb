@using SkyBookWeb.Core.Entities;

@model Category

<div class="container-fluid">
    <a href="#" class="text-decoration-none text-secondary small fw-medium d-inline-flex align-items-center gap-1 mb-3">
        <i class="bi bi-arrow-left"></i> Back to categories
    </a>
    <div class="card border shadow-sm overflow-hidden">
        <div class="card-header text-white py-3 px-4" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
            <h5 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>Delete Category</h5>
            <p class="mb-0 small" style="color: #1DB954;">Delete a category for your products</p>
        </div>
        <div class="card-body p-4">
            <form method="post" asp-action="Delete">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Category Name</label>
                    <input asp-for="Name" type="text" name="Name" disabled class="form-control" placeholder="Enter category name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" name="DisplayOrder" disabled class="form-control" placeholder="Enter display order" />
                    <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn fw-semibold btn-danger">Delete Category</button>
                    <a asp-controller="Category" asp-action="Index" class="btn btn-light fw-medium">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
